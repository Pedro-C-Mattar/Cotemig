@page "/filmes/delete"
@inject CrudBlazor.Data.ApplicationDbContext DB
@using CrudBlazor.Data
@inject NavigationManager NavigationManager
@using Microsoft.EntityFrameworkCore

<PageTitle>Delete</PageTitle>

<h1>Delete</h1>

<h3>Are you sure you want to delete this?</h3>
<div>
    <h4>Filmes</h4>
    <hr />
    @if (filme is null)
    {
        <p><em>Loading...</em></p>
    }
    else {
        <dl class="row">
            <dt class="col-sm-2">Name</dt>
            <dd class="col-sm-10">@filme.Nome</dd>
        </dl>
        <EditForm method="post" Model="filme" OnValidSubmit="DeleteFilmes" FormName="delete" Enhance>
            <button type="submit" class="btn btn-danger" disabled="@(filme is null)">Delete</button> |
            <a href="/filmes">Back to List</a>
        </EditForm>
    }
</div>

@code {
    Filmes? filme;

    [SupplyParameterFromQuery]
    public int Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        filme = await DB.Film.FirstOrDefaultAsync(f => f.Id == Id);

        if (filme is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }

    public async Task DeleteFilmes()
    {
        DB.Film.Remove(filme!);
        await DB.SaveChangesAsync();
        NavigationManager.NavigateTo("/filmes");
    }
}
