@page "/cidades/delete"
@inject CrudBlazor.Data.ApplicationDbContext DB
@using CrudBlazor.Data
@inject NavigationManager NavigationManager
@using Microsoft.EntityFrameworkCore

<PageTitle>Delete</PageTitle>

<h1>Delete</h1>

<h3>Are you sure you want to delete this?</h3>
<div>
    <h4>Cidade</h4>
    <hr />
    @if (cidade is null)
    {
        <p><em>Loading...</em></p>
    }
    else {
        <dl class="row">
            <dt class="col-sm-2">Name</dt>
            <dd class="col-sm-10">@cidade.Name</dd>
        </dl>
        <EditForm method="post" Model="cidade" OnValidSubmit="DeleteCidade" FormName="delete" Enhance>
            <button type="submit" class="btn btn-danger" disabled="@(cidade is null)">Delete</button> |
            <a href="/cidades">Back to List</a>
        </EditForm>
    }
</div>

@code {
    Cidade? cidade;

    [SupplyParameterFromQuery]
    public int Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        cidade = await DB.Cid.FirstOrDefaultAsync(m => m.Id == Id);

        if (cidade is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }

    public async Task DeleteCidade()
    {
        DB.Cid.Remove(cidade!);
        await DB.SaveChangesAsync();
        NavigationManager.NavigateTo("/cidades");
    }
}
