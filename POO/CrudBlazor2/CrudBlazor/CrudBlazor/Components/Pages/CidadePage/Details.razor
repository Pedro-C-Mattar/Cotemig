@page "/cidades/details"
@inject CrudBlazor.Data.ApplicationDbContext DB
@using CrudBlazor.Data
@inject NavigationManager NavigationManager
@using Microsoft.EntityFrameworkCore

<PageTitle>Details</PageTitle>

<h1>Details</h1>

<div>
    <h4>Cidade</h4>
    <hr />
    @if (cidade is null)
    {
        <p><em>Loading...</em></p>
    }
    else {
        <dl class="row">
            <dt class="col-sm-2">Name</dt>
            <dd class="col-sm-10">@cidade.Name</dd>
        </dl>
        <div>
            <a href="@($"/cidades/edit?id={cidade.Id}")">Edit</a> |
            <a href="@($"/cidades")">Back to List</a>
        </div>
    }
</div>

@code {
    Cidade? cidade;

    [SupplyParameterFromQuery]
    public int Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        cidade = await DB.Cid.FirstOrDefaultAsync(m => m.Id == Id);

        if (cidade is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }
}
