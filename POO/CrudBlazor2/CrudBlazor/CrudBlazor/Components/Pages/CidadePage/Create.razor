@page "/cidades/create"
@inject CrudBlazor.Data.ApplicationDbContext DB
@using CrudBlazor.Data
@inject NavigationManager NavigationManager

<PageTitle>Create</PageTitle>

<h1>Create</h1>

<h4>Cidade</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <EditForm method="post" Model="Cidade" OnValidSubmit="AddCidade" FormName="create" Enhance>
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" />
            <div class="mb-3">
                <label for="name" class="form-label">Name:</label> 
                <InputText id="name" @bind-Value="Cidade.Name" class="form-control" /> 
                <ValidationMessage For="() => Cidade.Name" class="text-danger" /> 
            </div>        
            <button type="submit" class="btn btn-primary">Create</button>
        </EditForm>
    </div>
</div>

<div>
    <a href="/cidades">Back to List</a>
</div>

@code {

    [SupplyParameterFromForm]
    public Cidade Cidade { get; set; } = new();

    // To protect from overposting attacks, see https://aka.ms/RazorPagesCRUD
    public async Task AddCidade()
    {
        DB.Cid.Add(Cidade);
        await DB.SaveChangesAsync();
        NavigationManager.NavigateTo("/cidades");
    }
}
