@page "/estados/delete"
@inject CrudBlazor.Data.ApplicationDbContext DB
@using CrudBlazor.Data
@inject NavigationManager NavigationManager
@using Microsoft.EntityFrameworkCore

<PageTitle>Delete</PageTitle>

<h1>Delete</h1>

<h3>Are you sure you want to delete this?</h3>
<div>
    <h4>Estado</h4>
    <hr />
    @if (estado is null)
    {
        <p><em>Loading...</em></p>
    }
    else {
        <dl class="row">
            <dt class="col-sm-2">Name</dt>
            <dd class="col-sm-10">@estado.Name</dd>
        </dl>
        <EditForm method="post" Model="estado" OnValidSubmit="DeleteEstado" FormName="delete" Enhance>
            <button type="submit" class="btn btn-danger" disabled="@(estado is null)">Delete</button> |
            <a href="/estados">Back to List</a>
        </EditForm>
    }
</div>

@code {
    Estado? estado;

    [SupplyParameterFromQuery]
    public int Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        estado = await DB.Est.FirstOrDefaultAsync(m => m.Id == Id);

        if (estado is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }

    public async Task DeleteEstado()
    {
        DB.Est.Remove(estado!);
        await DB.SaveChangesAsync();
        NavigationManager.NavigateTo("/estados");
    }
}
