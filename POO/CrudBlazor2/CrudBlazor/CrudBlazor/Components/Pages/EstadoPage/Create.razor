@page "/estados/create"
@inject CrudBlazor.Data.ApplicationDbContext DB
@using CrudBlazor.Data
@inject NavigationManager NavigationManager

<PageTitle>Create</PageTitle>

<h1>Create</h1>

<h4>Estado</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <EditForm method="post" Model="Estado" OnValidSubmit="AddEstado" FormName="create" Enhance>
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" />
            <div class="mb-3">
                <label for="name" class="form-label">Name:</label> 
                <InputText id="name" @bind-Value="Estado.Name" class="form-control" /> 
                <ValidationMessage For="() => Estado.Name" class="text-danger" /> 
            </div>        
            <button type="submit" class="btn btn-primary">Create</button>
        </EditForm>
    </div>
</div>

<div>
    <a href="/estados">Back to List</a>
</div>

@code {

    [SupplyParameterFromForm]
    public Estado Estado { get; set; } = new();

    // To protect from overposting attacks, see https://aka.ms/RazorPagesCRUD
    public async Task AddEstado()
    {
        DB.Est.Add(Estado);
        await DB.SaveChangesAsync();
        NavigationManager.NavigateTo("/estados");
    }
}
