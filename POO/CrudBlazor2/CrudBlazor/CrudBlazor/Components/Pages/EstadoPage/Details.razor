@page "/estados/details"
@inject CrudBlazor.Data.ApplicationDbContext DB
@using CrudBlazor.Data
@inject NavigationManager NavigationManager
@using Microsoft.EntityFrameworkCore

<PageTitle>Details</PageTitle>

<h1>Details</h1>

<div>
    <h4>Estado</h4>
    <hr />
    @if (estado is null)
    {
        <p><em>Loading...</em></p>
    }
    else {
        <dl class="row">
            <dt class="col-sm-2">Name</dt>
            <dd class="col-sm-10">@estado.Name</dd>
        </dl>
        <div>
            <a href="@($"/estados/edit?id={estado.Id}")">Edit</a> |
            <a href="@($"/estados")">Back to List</a>
        </div>
    }
</div>

@code {
    Estado? estado;

    [SupplyParameterFromQuery]
    public int Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        estado = await DB.Est.FirstOrDefaultAsync(m => m.Id == Id);

        if (estado is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }
}
